# 서버 포트
PORT=4000

# OpenAI API 키는 서버에서만 사용됩니다. 프론트엔드에 노출하지 마세요.
OPENAI_API_KEY=your_openai_api_key_here

# 선택: 사용할 모델을 바꿀 수 있습니다.
OPENAI_MODEL=gpt-4o-mini

# 선택: PDF 보고서 폰트 경로(한글 PDF 생성을 위해 Noto Sans KR 같은 TTF 권장)
REPORT_FONT_PATH=

# 선택: Semantic Scholar API 키가 있으면 검색 제한 완화에 사용할 수 있습니다.
SEMANTIC_SCHOLAR_API_KEY=
