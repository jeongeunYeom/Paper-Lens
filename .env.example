# 서버 포트
PORT=4000

# 선택: OpenAI API 키가 있으면 AI 요약을 사용합니다. 없으면 규칙 기반 요약으로 동작합니다.
OPENAI_API_KEY=

# 선택: 사용할 모델을 바꿀 수 있습니다.
OPENAI_MODEL=gpt-4o-mini

# 테스트용: true로 설정하면 OpenAI API를 호출하지 않고 mock 요약을 반환합니다.
USE_MOCK_SUMMARY=false

# 선택: PDF 보고서 폰트 경로(한글 PDF 생성을 위해 Noto Sans KR 같은 TTF 권장)
REPORT_FONT_PATH=

# 선택: Semantic Scholar API 키가 있으면 검색 제한 완화에 사용할 수 있습니다.
SEMANTIC_SCHOLAR_API_KEY=
