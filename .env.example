# 서버 포트
PORT=4000

# 필수: OpenAI API 요약에 사용할 서버 전용 API 키입니다. 클라이언트 코드에 넣지 마세요.
OPENAI_API_KEY=

# 선택: 사용할 요약 모델을 바꿀 수 있습니다.
OPENAI_MODEL=gpt-4o-mini

# 선택: 영문 논문 전체 번역에 사용할 모델과 입력 제한을 조정합니다.
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
MAX_TRANSLATION_INPUT_CHARS=30000
TRANSLATION_CHUNK_SIZE=6000

# 선택: 토큰 예상 비용 계산용 단가(USD / 1M tokens). 모델 가격 변경 시 Render 환경변수에서 조정하세요.
OPENAI_INPUT_PRICE_PER_1M_TOKENS=0.15
OPENAI_OUTPUT_PRICE_PER_1M_TOKENS=0.60

# 테스트용: true로 설정하면 OpenAI API를 호출하지 않고 mock 요약을 반환합니다.
USE_MOCK_SUMMARY=false

# 선택: true이면 OpenAI API 키가 없거나 호출 실패 시 규칙 기반 요약으로 대체합니다. 기본값은 false입니다.
ALLOW_RULE_BASED_FALLBACK=false

# 선택: PDF 보고서 폰트 경로(한글 PDF 생성을 위해 Noto Sans KR 같은 TTF 권장)
REPORT_FONT_PATH=

# 선택: Semantic Scholar API 키가 있으면 검색 제한 완화에 사용할 수 있습니다.
SEMANTIC_SCHOLAR_API_KEY=
